    <P Name="name">fcn</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">83</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function LTR = fcn(TireFz)
% 分配物理量
FzL=sum(TireFz(1:5));
FzR=sum(TireFz(6:10));
% 进行计算
LTR=(FzL-FzR)/(FzL+FzR);
end
</P>
