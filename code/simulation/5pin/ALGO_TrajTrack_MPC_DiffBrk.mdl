__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_37.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="37">
  <P Name="name">STL_Model_50per</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">37</P>
  <P Name="ssIdHighWaterMark">19</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">3</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">SlidingLibra_Fun</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">37</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">%% 函数：滑动天平模型非线性状态转移函数
% 采用x(k+1) = f(x(k),u(k))的方式改写STL模型，以用于其线性化的实施
% 可以选择按照dx = f(x,u)的方式来改写STL模型
%%% 输入：tspan [t0 tf]
%         Ts    采样时间
%         u     [ax;      01
%                ay;      02
%                droll;   03
%                droll;   04
%                ddroll;  05
%                ddyaw]   06
%         Params 
%                ka 范数的阶数       01
%                ke 方形系数         02
%                kx x坐标轴的范围    03
%                ky y坐标轴的范围    04
%                kz z坐标轴的范围    05
%                h  曲面底部的静高   06
%                ap 曲线的半长轴     07
%                bp 曲线的半短轴     08 
%                pr 曲线的幂次       09
%                m  晃动部分质量     10
%              damp 小球晃动的阻尼   11
%             xdamp 浴盆x向移动阻尼  12
%              adec 加速度换算系数   13
%           dev_def 静态偏置距离     14 
%             vxdec x方向速度衰减    15
%             axpow 加速度衰减系数   16
%             dev_a dev自衰减系数    17
%             dev_b dev输入系数      18
%        
%  
function [GenForce,basin1_pos,basin2_pos,surf_pos,basin1_v,basin2_v,surf_v,dev,STL_state_vec]  = SlidingLibra_Fun(STL_input)% ddx,ddy,roll,ddf,dth,ddth
    % 初始化输出状态量
    persistent STL_state Params Ts
    if isempty(Ts)
        Ts = 0.01; % 采样时间
        STL_state.x0 = 0;% 初始化状态变量
        STL_state.dx0 = 0;
        STL_state.x1 = 0;
        STL_state.dx1 = 0;
        STL_state.y1 = 0;
        STL_state.dy1 = 0;
        STL_state.x2 = 0;
        STL_state.dx2 = 0;
        STL_state.y2 = 0;
        STL_state.dy2 = 0;
        STL_state.dev = 0;
        STL_state.basin1_pos = [0,0,0];
        STL_state.basin2_pos = [0,0,0];
        STL_state.basin1_v = [0,0,0];
        STL_state.basin2_v = [0,0,0];
        STL_state.surf_pos = [0,0];
        STL_state.surf_v = [0,0];
%         Params 
%                ka 范数的阶数       01
%                ke 方形系数         02
%                kx x坐标轴的范围    03
%                ky y坐标轴的范围    04
%                kz z坐标轴的范围    05
%                h  曲面底部的静高   06
%                ap 曲线的半长轴     07
%                bp 曲线的半短轴     08 
%                pr 曲线的幂次       09
%                m  晃动部分质量     10
%              damp 小球晃动的阻尼   11
%             xdamp 浴盆x向移动阻尼  12
%              adec 加速度换算系数   13
%               dev 偏置距离         14 
%             vxdec x方向速度衰减    15
%             axpow 加速度衰减系数   16
%             dev_a dev自衰减系数    17
%             dev_b dev输入系数      18
        Params = [3.593, 7.7146, 1.0424, 1.2903, 3.2396, 1.2631, ...
            15.5018, 0.6069, 0.53091, 14498.6641, 0.17393, 3.8431, ...
            0.55681, 3.1186, 9.1364, 0.42295, 20.1983, 0.1208];
        exh = 0.77;
        Params(6) = Params(6) + exh;

    end
    STL_input(abs(STL_input)&gt;20) = 0;
    ddx = -STL_input(1); % ddx是车辆受到的，但是转换为液体受到的，就要加个负号
    ddy = -STL_input(2); % ddy是车辆受到的，但是转换为液体受到的，就要加个负号
    roll = STL_input(3);
    ddf = -STL_input(4);  % ddf是车辆受到的，但是转换为液体受到的，就要加个负号
    dth = STL_input(5);
    ddth = STL_input(6); % ddth是车辆受到的，但是转换为液体受到的，就要加个负号

    %% 2D计算程序
    %% 仿真参数设置
    % 时间与绘图设置
    Eps = 1e-5; % 数值求导的微小步长

    % 设置曲面方程
    surf4lm = Surface4LumpedMass(Params(1),Params(2),Params(3),Params(4),Params(5),Params(6));
    Surface = @(x)surf4lm.Value(x);

    
    % 设置曲线方程
    ap = Params(7);
    bp = Params(8);
    pr = Params(9);
    Curve = @(x) real(sign(-bp*(1-x.*x/(ap*ap)))*abs(-bp*(1-x.*x/(ap*ap))).^(1/pr)).*sign(ap-abs(x));
    
    % 设置物理属性
    m = Params(10)/2;     % kg 单个小球质量
    damp = Params(11);    %   曲面内晃动阻尼系数
    xdamp = Params(12);   %   曲面沿x方向滑动阻尼系数
    adec = Params(13);    %   加速度换算系数
    dev0 = Params(14);    %   偏置距离
    vxdec = Params(15);
    damp = [vxdec*damp, damp, (1+vxdec)*damp/2];
    axpow = Params(16);
    dev_a = Params(17);
    dev_b = Params(18);
    
    %% 初始状态设置
    basin1_pos = [STL_state.x1,STL_state.y1,Surface([STL_state.x1,STL_state.y1])];% 第一个球
    basin1_v = STL_state.basin1_v; % 第一个球的速度
    basin2_pos = [STL_state.x2,STL_state.y2,Surface([STL_state.x2,STL_state.y2])];% 第二个球
    basin2_v = STL_state.basin2_v; % 第二个球的速度
    surf_pos = [STL_state.x0, Curve(STL_state.x0)]; % 滑动浴盆的位置
    surf_v = STL_state.surf_v; % 滑动浴盆的速度
    dev = dev0 + STL_state.dev;
    
    %% 定义输入量
    a =  [ddx;ddy;-9.806];  % az
    f = roll;
        

    %% 更新曲面的滑动
    %计算当前位置的曲线斜率
    surfGrad=NumGrad(Curve,surf_pos(1),Eps);
    surfGradVec=[1,surfGrad];
    theta=atan(surfGrad);
    %计算曲线姿态
    ax=(sign(a(1))*abs(a(1))^axpow)*adec;
    az=a(3);
    a__=[ax,az]&apos;;
    %计算无阻碍时的新位置
    pos0_=surf_pos+surf_v*Ts+1/2*a__&apos;*Ts*Ts;
    move0_=pos0_-surf_pos;
    dist0=norm(move0_);
    %计算有阻挡时的位置更新
    dtheta=sign(dot([surfGrad,-1],move0_))*acos(dot(surfGradVec,move0_)/(norm(surfGradVec)*dist0));
    newPosx_=pos0_(1)-dist0*sin(theta)*sin(dtheta);
    pos0_=surf_pos;
    surf_pos=[newPosx_,Curve(newPosx_)];
    %根据位移差距计算当前速度
    move_=surf_pos-pos0_;
    surf_v=[move_(1)/Ts,move_(2)/Ts]*(1-Ts*xdamp);

    %% 更新两个浴盆的分离（dev变化）
    dev = dev0 + (1-dev_a*Ts)*(dev-dev0) + (dev_b*Ts)*abs(dth);

    %% 更新集中质量1相对曲面的摆动
    % 计算当前位置的曲面梯度
    Grad=NumGrad(Surface,basin1_pos(1:2)&apos;,Eps);
    NormVec=[Grad&apos;,-1];
    % 计算曲面姿态
    ax=a(1);ay=a(2);az=a(3);
    posx=basin1_pos(1)+surf_pos(1)+dev;
    posy=basin1_pos(2);
    posz=basin1_pos(3)+surf_pos(2);
    a_=[ax                   - ddth*posy;...
       (ay*cos(f)-az*sin(f)) + ddth*posx - ddf*posz;...
       (az*cos(f)+ay*sin(f)) + ddf*posy];
    %计算无阻碍时的新位置
    pos0=basin1_pos+basin1_v*Ts+1/2*a_&apos;*Ts*Ts;
    move0=pos0-basin1_pos;
    %计算有阻挡时的位置更新
    proj=move0-dot(move0,NormVec)*NormVec/norm(NormVec);
    newPosx=basin1_pos(1)+proj(1);
    newPosy=basin1_pos(2)+proj(2);
    pos0=basin1_pos;
    basin1_pos=[newPosx,newPosy,Surface([newPosx,newPosy])];
    
    %根据位移差距计算当前速度
    move=basin1_pos-pos0;
    v0=basin1_v;
    basin1_v=move/Ts.*(1-Ts*damp);
    %根据速度差计算加速度
    acc=(basin1_v-v0)/Ts;

    %根据加速度计算力
    force1 = -m*(acc-a_&apos;);
    %根据力和位置计算力矩
    fx=force1(1);fy=force1(2);fz=force1(3);
    moment1 = [(posy*fz-posz*fy);(posz*fx-posx*fz);(posx*fy-posy*fx)];


    %% 更新集中质量2相对曲面的摆动
    % 计算当前位置的曲面梯度
    Grad=NumGrad(Surface,basin2_pos(1:2)&apos;,Eps);
    NormVec=[Grad&apos;,-1];
    % 计算曲面姿态
    posx=basin2_pos(1)+surf_pos(1)-dev;
    posy=basin2_pos(2);
    posz=basin2_pos(3)+surf_pos(2);
   
    a_=[ax                   - ddth*posy;...
       (ay*cos(f)-az*sin(f)) + ddth*posx - ddf*posz;...
       (az*cos(f)+ay*sin(f)) + ddf*posy];
    %计算无阻碍时的新位置
    pos0=basin2_pos+basin2_v*Ts+1/2*a_&apos;*Ts*Ts;
    move0=pos0-basin2_pos;
    %计算有阻挡时的位置更新
    proj=move0-dot(move0,NormVec)*NormVec/norm(NormVec);
    newPosx=basin2_pos(1)+proj(1);
    newPosy=basin2_pos(2)+proj(2);
    pos0=basin2_pos;
    basin2_pos=[newPosx,newPosy,Surface([newPosx,newPosy])];
    %根据位移差距计算当前速度
    move=basin2_pos-pos0;
    v0=basin2_v;
    basin2_v=move/Ts.*(1-Ts*damp);
    %根据速度差计算加速度
    acc=(basin2_v-v0)/Ts;

    %根据加速度计算力
    force2 = -m*(acc-a_&apos;);
    %根据力和位置计算力矩
    fx=force2(1);fy=force2(2);fz=force2(3);
    moment2 = [(posy*fz-posz*fy);(posz*fx-posx*fz);(posx*fy-posy*fx)];


    %记录数据
    Force=force1&apos;+force2&apos;;
    Moment=moment1+moment2;
    
    STL_state.basin1_pos = basin1_pos;
    STL_state.basin2_pos = basin2_pos;
    STL_state.basin1_v = basin1_v;
    STL_state.basin2_v = basin2_v;
    STL_state.dev = dev - dev0;
    STL_state.surf_pos = surf_pos;
    STL_state.surf_v = surf_v;
    STL_state.x0 = surf_pos(1);
    STL_state.x1 = basin1_pos(1);
    STL_state.x2 = basin2_pos(1);
    STL_state.y1 = basin1_pos(2);
    STL_state.y2 = basin2_pos(2);
    STL_state_vec = [surf_pos(1); surf_v(1); ...
        basin1_pos(1); basin1_pos(2); basin1_v(1); basin1_v(2); ...
        basin2_pos(1); basin2_pos(2); basin1_v(1); basin1_v(2); dev - dev0]&apos;;
    GenForce = [Force;Moment]&apos;;
end

</P>
      </eml>
    </state>
    <data SSID="7" name="STL_input">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="GenForce">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="12" name="basin1_pos">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="13" name="basin2_pos">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="14" name="surf_pos">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
