      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function PresBrk = DiffBrk(brkPresCmd)
    pL1 = brkPresCmd(1);
    pR1 = brkPresCmd(2);
    pL2 = brkPresCmd(3);
    pR2 = brkPresCmd(4);
    PresBrk = zeros(10,1); % 初始化制动压力指令

    PresBrk([2 3]) = abs(pL1);
    PresBrk([7 8]) = abs(pR1);
    PresBrk([4 5]) = abs(pL2);
    PresBrk([9 10]) = abs(pR2);
end

</P>
      </eml>
    </state>
