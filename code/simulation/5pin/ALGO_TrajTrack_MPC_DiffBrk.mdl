__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_52.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="52">
  <P Name="name">DLSP_Model_50per</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">52</P>
  <P Name="ssIdHighWaterMark">10</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">4</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">DualLSP_Fcn</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">52</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">%% 函数：双摆线性状态转移函数
%%% 输入：Theta0 初始状态，[th1 dth1 th2 dth2]
%         Ts    采样时间
%         DLSP_input 输入量，[ay,ddroll,ddyaw,roll]
%         Params Dual-LSP模型的参数共7个
%                h0 m0距侧倾中心高度 01
%                hp mp距侧倾中心高度 02
%                lp mp的摆长         03
%                m0 m0的质量大小     04
%                x0 两摆前移距离     05
%                d  两摆半分离距     06
%                cd 摆动阻尼         07
%
%%% 输出：GenForce 输出力，3维向量分别为Fy Mx Mz
%        Theta 下一个时刻的状态，同样为[th1 dth1 th2 dth2]
%

function [GenForce,Theta] = DualLSP_Fcn(DLSP_input,Theta_in,dParams)
    persistent Ts ParamsDLSP coeff_theta coeff_params
    persistent Theta0
    if isempty(Ts)
        Theta0 = zeros(4,1);
        Ts = 0.01;
        coeff_theta = 0.9;
        coeff_params = 0.9;
        % ParamsDLSP = [1.5, 0.13, 0.77, 0.4763, 0.0, 3.5, 0.53];
        ParamsDLSP = [1.5, 0.13, 0.77, 0.4763, 0.0, 3.5, 0.33];
        exh = 0.77;
        ParamsDLSP(1:2) = ParamsDLSP(1:2) + exh;
    end
    % 获取Dual-LSP模型参数

    [h0,hp,lp,m0,mp,x0,d,cd] = Dual_LSP_getParams(ParamsDLSP+coeff_params*dParams&apos;); 
   
    g = 9.806;
    % 获取当期时刻状态量
    Theta0 = (1-coeff_theta)*Theta0+coeff_theta*Theta_in;
    th1 = Theta0(1);
    dth1 = Theta0(2);
    th2 = Theta0(3);
    dth2 = Theta0(4);
    
    % 获取当前时刻输入量
    ddy = DLSP_input(1); 
    ddf = DLSP_input(2);
    ddyaw = DLSP_input(3); 
    f = DLSP_input(4); 


    % 计算当前时刻动力学
    ddy1 = ddy + ddyaw*(x0 + d);
    ddy2 = ddy + ddyaw*(x0 - d);
    x1 = x0 + d;
    x2 = x0 - d;
    ddth1 = -(1/lp*ddy1 + (2-hp/lp)*ddf + g/lp*(f + th1) + cd*dth1);
    ddth2 = -(1/lp*ddy2 + (2-hp/lp)*ddf + g/lp*(f + th2) + cd*dth2);
    dth1 = dth1 + Ts*ddth1;
    dth2 = dth2 + Ts*ddth2;
    th1 = th1 + Ts*dth1;
    th2 = th2 + Ts*dth2;
    Theta = [th1 dth1 th2 dth2]&apos;;
    Fy1 = 1/2*(-(mp + m0)*ddy1 + (m0*h0 + mp*hp)*ddf - mp*lp*ddth1);
    Fy2 = 1/2*(-(mp + m0)*ddy2 + (m0*h0 + mp*hp)*ddf - mp*lp*ddth2);
    Fy = Fy1 + Fy2;
    Mx = (m0*h0 + mp*hp)*(ddy + ddyaw*x0) - (m0*h0^2 + mp*hp^2)*ddf ...
        + (m0*h0 + mp*hp)*g*f + mp*hp*lp*(ddth1 + ddth2)/2 - 1/2*mp*lp*g*(th1 + th2);
    Mz = -1/2*((x1 + x2)*(m0 + mp)*ddy - (m0 + mp)*(x1^2 + x2^2)*ddyaw ...
        + (x1 + x2)*(m0*h0 + mp*hp)*ddf - mp*lp*(x2*ddth2 + x1*ddth1));
    
    GenForce = [Fy Mx Mz];

    % 更新存储的状态量
    Theta0 = Theta;
end

function [h0,hp,lp,m0,mp,x0,d,cd] = Dual_LSP_getParams(Params)
    m = 14462; % TotalWeight
    h0 = Params(1);
    hp = Params(2);
    lp = Params(3);
    m0 = m*Params(4);
    mp = m - m0;
    x0 = Params(5);
    d = Params(6);
    cd = Params(7);
end</P>
      </eml>
    </state>
    <data SSID="5" name="GenForce">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="6" name="DLSP_input">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="10" name="Theta_in">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="Theta">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="9" name="dParams">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <transition SSID="2">
      <P Name="labelString">{eML_blk_kernel();}</P>
      <P Name="labelPosition">[28.125 13.875 102.544 14.964]</P>
      <P Name="fontSize">12</P>
      <src>
        <P Name="intersection">[0 0 1 0 23.5747 14.625 0 0]</P>
      </src>
      <dst>
        <P Name="SSID">3</P>
        <P Name="intersection">[1 0 -1 0 23.5747 42.5747 0 0]</P>
      </dst>
      <P Name="midPoint">[23.5747 24.9468]</P>
      <P Name="dataLimits">[21.175 25.975 14.625 42.575]</P>
      <P Name="subviewer">52</P>
      <P Name="drawStyle">SMART</P>
      <slide>
        <P Name="sticky">BOTH_STICK</P>
      </slide>
      <P Name="executionOrder">1</P>
    </transition>
    <junction SSID="3">
      <P Name="position">[23.5747 49.5747 7]</P>
      <P Name="subviewer">52</P>
      <P Name="type">CONNECTIVE_JUNCTION</P>
    </junction>
  </Children>
</chart>

